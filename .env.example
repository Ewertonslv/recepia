# ============================================================================
# Database — em docker-compose, postgres é o nome do service
# ============================================================================
DATABASE_URL=postgresql://recepia:CHANGE_THIS@postgres:5432/recepia
POSTGRES_PASSWORD=CHANGE_THIS

# ============================================================================
# Auth — GERA TODAS com `openssl rand -hex 32`
# Boot vai FALHAR se essas usarem "change-me*" ou < 32 chars.
# ============================================================================
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

ADMIN_API_KEY=CHANGE_ME_use_openssl_rand_hex_32

# ============================================================================
# Evolution API (WhatsApp self-hosted)
# Em docker-compose, evolution é o nome do service.
# ============================================================================
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=CHANGE_ME_use_openssl_rand_hex_32
# A Evolution API NÃO assina o webhook com HMAC. Deixe vazio (validação desligada).
# Pra proteger o webhook em produção, use um token na URL — não este secret.
EVOLUTION_WEBHOOK_SECRET=

# URL que o Evolution usa pra entregar o webhook na Recepia.
# Em docker-compose, Evolution e API são containers: use o nome do service (api),
# NÃO localhost (pro Evolution, localhost é ele mesmo).
# Em prod, a URL pública: https://recepia.app.br.
PUBLIC_WEBHOOK_URL=http://api:8000

# ============================================================================
# Groq (IA classificadora — grátis em console.groq.com)
# ============================================================================
GROQ_API_KEY=gsk_xxxxx_cole_a_sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# Operação
# ============================================================================
INTERVALO_CONFIRMACAO_HORAS=24
INTERVALO_LEMBRETE_HORAS=2
TIMEZONE=America/Sao_Paulo

# ============================================================================
# Ambiente
# ============================================================================
DEBUG=true
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173,https://recepia.app.br
